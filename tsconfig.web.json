{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "electron/preload/*.d.ts",
    "frontend/src/*.d.ts",
    "frontend/src/**/*",
    "frontend/src/**/*.vue",
    "frontend/*.d.ts",
    "shared/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "noImplicitAny": true,
    "moduleResolution": "Bundler",
    "types": ["vitest/globals"],
    "paths": {
      "@renderer/*": ["./frontend/src/*"],
      "@shared/*": ["./shared/*"],
      "#build/ui/*": ["./frontend/node_modules/.nuxt-ui/ui/*"]
    }
  },
  "vueCompilerOptions": {
    "plugins": ["vue-router/volar/sfc-typed-router", "vue-router/volar/sfc-route-blocks"]
  }
}
